@model IEnumerable<MyWeb.Models.Book>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["PageTitle"];
    Layout = "~/Views/Shared/_HomeLayout.cshtml";

    var bookSections = new[] {
        "Section_Trending",
        "Section_Classic",
        "Section_Love",
        "Section_Romance",
        "Section_Kids"
    };
}

<div class="p-5 mb-5 rounded-3 shadow-sm text-center" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">
    <div class="container-fluid py-4">
        <h1 class="display-5 fw-bold text-white mb-3">
            <i class="fas fa-book-open me-3 text-warning"></i>@Localizer["Hero_Title"]
        </h1>
        <p class="col-md-8 mx-auto fs-5 text-light opacity-75">
            @Localizer["Hero_Desc"]
        </p>
    </div>
</div>

<div class="container pb-5">
    @foreach (var sectionKey in bookSections)
    {
        <div class="book-section mb-5 position-relative">

            <div class="d-flex justify-content-between align-items-end mb-3 px-2">
                <h3 class="fw-bold text-dark m-0">@Localizer[sectionKey]</h3>

                <a href="#" class="text-primary text-decoration-none fw-bold small hover-link">
                    @Localizer["Link_SeeAll"] <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>

            <div class="carousel-wrapper position-relative">

                <button class="btn btn-primary rounded-circle shadow scroll-btn scroll-left" onclick="scrollCarousel(this, -1)">
                    <i class="fas fa-chevron-left"></i>
                </button>

                <div class="book-carousel d-flex gap-4 pb-3 pt-2 px-2">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var book in Model)
                        {
                            string coverUrl = !string.IsNullOrEmpty(book.CoverImageUrl)
                            ? book.CoverImageUrl
                            : "https://via.placeholder.com/400x550?text=No+Cover";

                            <div class="book-item">
                                <div class="card h-100 border-0 shadow-sm book-card bg-white">

                                    <div class="position-relative overflow-hidden" style="height: 320px; border-radius: 12px 12px 0 0;">
                                        <img src="@coverUrl" class="card-img-top w-100 h-100" style="object-fit: cover;" alt="Cover of @book.Title">
                                    </div>

                                    <div class="card-body d-flex flex-column p-3">
                                        <h5 class="card-title fw-bold text-dark mb-2 line-clamp-2" style="min-height: 48px;">
                                            @book.Title
                                        </h5>

                                        <p class="card-text text-muted small mb-1">
                                            <i class="fas fa-pen-nib me-2 text-primary"></i>
                                            <strong>@Localizer["Label_Author"]</strong>
                                            <a href="/Books/Author?name=@book.Author" class="text-decoration-none fw-bold text-secondary author-link">
                                                @book.Author
                                            </a>
                                        </p>

                                        <p class="card-text text-muted small mb-4">
                                            <i class="fas fa-calendar-alt me-2 text-primary"></i>
                                            <strong>@Localizer["Label_Year"]</strong> @book.YearPublished
                                        </p>

                                        <div class="mt-auto d-flex justify-content-between gap-2">
                                            <a href="#" class="btn btn-outline-primary btn-sm w-50 fw-bold">
                                                <i class="fas fa-info-circle me-1"></i>@Localizer["Button_Details"]
                                            </a>
                                            <a href="@Url.Action("ReadFirst", "Home", new { bookId = book.Id })" class="btn btn-primary btn-sm w-50 fw-bold shadow-sm">
                                                <i class="fas fa-book-reader me-1"></i>@Localizer["Button_Read"]
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <button class="btn btn-primary rounded-circle shadow scroll-btn scroll-right" onclick="scrollCarousel(this, 1)">
                    <i class="fas fa-chevron-right"></i>
                </button>

            </div>
        </div>
    }
</div>

<style>
    body.dark-theme {
        background-color: #f4f6f9;
    }

    .book-carousel {
        overflow-x: auto;
        scroll-behavior: smooth;
        scroll-snap-type: x mandatory;
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

        .book-carousel::-webkit-scrollbar {
            display: none;
        }

    .book-item {
        flex: 0 0 calc(33.333% - 1rem);
        scroll-snap-align: start;
    }

    .book-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 12px;
    }

        .book-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.12) !important;
        }

    .author-link:hover {
        color: #0d6efd !important;
        text-decoration: underline !important;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .scroll-btn {
        position: absolute;
        top: 45%;
        transform: translateY(-50%);
        z-index: 10;
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: all 0.3s ease;
    }

    .carousel-wrapper:hover .scroll-btn {
        opacity: 0.9;
    }

    .scroll-btn:hover {
        opacity: 1;
        transform: translateY(-50%) scale(1.1);
    }

    .scroll-left {
        left: -20px;
    }

    .scroll-right {
        right: -20px;
    }

    @@media (max-width: 992px) {
        .book-item {
            flex: 0 0 calc(50% - 0.75rem);
        }
    }

    @@media (max-width: 576px) {
        .book-item {
            flex: 0 0 100%;
        }

        .scroll-btn {
            display: none;
        }
    }
</style>

<script>
    function scrollCarousel(button, direction) {
        const container = button.parentElement.querySelector('.book-carousel');
        const scrollAmount = container.clientWidth;

        container.scrollBy({
            left: scrollAmount * direction,
            behavior: 'smooth'
        });
    }
</script>