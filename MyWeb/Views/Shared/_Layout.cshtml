<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyWeb.styles.css" asp-append-version="true" />
</head>
<body class="dark-theme">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-glass border-bottom border-secondary sticky-top mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Books" asp-action="Index">
                    <i class="fas fa-book-reader me-2 text-primary"></i>MangaLibrary
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light hover-link" asp-controller="Books" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light hover-link" asp-controller="Books" asp-action="Create">
                                <i class="fas fa-plus-circle me-1"></i>Create
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        <partial name="_SelectLanguagePartial" />
                        <partial name="_LogionPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-secondary bg-black border-top border-secondary">
        <div class="container py-3 text-center">
            <small>&copy; 2026 - <span class="text-primary fw-bold">MyWeb</span> Application</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>