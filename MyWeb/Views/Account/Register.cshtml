@using MyWeb.ViewModels;
@model RegisterViewModel;
@{
    ViewData["Title"] = "Đăng ký";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">
    <div class="account-box">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-dark text-uppercase">Đăng Ký</h2>
            <p class="text-muted small">Tạo tài khoản mới để trải nghiệm dịch vụ</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold text-dark">Họ và Tên</label>
                <div class="input-group input-group-solid">
                    <span class="input-group-text bg-white border-0">
                        <i class="fas fa-user text-primary"></i>
                    </span>
                    <input asp-for="Name" class="form-control bg-white text-dark border-0 shadow-none" placeholder="Nhập họ tên..." />
                </div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold text-dark">Email</label>
                <div class="input-group input-group-solid">
                    <span class="input-group-text bg-white border-0">
                        <i class="fas fa-envelope text-primary"></i>
                    </span>
                    <input asp-for="Email" class="form-control bg-white text-dark border-0 shadow-none" placeholder="name@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-bold text-dark">Mật khẩu</label>
                <div class="input-group input-group-solid">
                    <span class="input-group-text bg-white border-0">
                        <i class="fas fa-lock text-primary"></i>
                    </span>
                    <input asp-for="Password" type="password" class="form-control bg-white text-dark border-0 shadow-none" placeholder="••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-bold text-dark">Xác nhận mật khẩu</label>
                <div class="input-group input-group-solid">
                    <span class="input-group-text bg-white border-0">
                        <i class="fas fa-check-circle text-primary"></i>
                    </span>
                    <input asp-for="ConfirmPassword" type="password" class="form-control bg-white text-dark border-0 shadow-none" placeholder="Nhập lại mật khẩu" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="d-grid mt-4">
                <input type="submit" value="Đăng Ký Ngay" class="btn btn-primary fw-bold shadow border-dark btn-lg" />
            </div>

            <p class="text-center mt-3 mb-0 text-dark small">
                Đã có tài khoản? <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-bold">Đăng nhập tại đây</a>
            </p>
            <div class="text-center mt-2">
                <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-muted small hover-link">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>