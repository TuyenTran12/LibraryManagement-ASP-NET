@using Microsoft.AspNetCore.Mvc.Localization
@using MyWeb.ViewModels

@model LoginViewModel
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["PageTitle"];
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">
    <div class="account-box">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-dark text-uppercase">@Localizer["PageTitle"]</h2>
            <p class="text-muted small">@Localizer["Desc"]</p>
        </div>

        <form asp-action="Login" method="post">            

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold text-dark">
                    @Localizer["Label_Email"]
                </label>
                <div class="input-group input-group-solid">
                    <span class="input-group-text bg-white border-0">
                        <i class="fas fa-envelope text-primary"></i>
                    </span>
                    <input asp-for="Email" class="form-control bg-white text-dark border-0 shadow-none"
                           placeholder="@Localizer["Placeholder_Email"]" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-bold text-dark">
                    @Localizer["Label_Password"]
                </label>
                <div class="input-group input-group-solid">
                    <span class="input-group-text bg-white border-0">
                        <i class="fas fa-lock text-primary"></i>
                    </span>
                    <input asp-for="Password" type="password" class="form-control bg-white text-dark border-0 shadow-none"
                           placeholder="@Localizer["Placeholder_Password"]" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input border-dark" />
                    <label class="form-check-label text-dark small" asp-for="RememberMe">
                        @Localizer["Label_RememberMe"]
                    </label>
                </div>
                <a asp-controller="Account" asp-action="VerifyEmail" class="text-decoration-none small fw-bold">
                    @Localizer["Link_ForgotPassword"]
                </a>
            </div>
            
            <div class="d-grid mb-3">
                <input type="submit" value="@Localizer["Button_Login"]" class="btn btn-primary fw-bold shadow border-dark btn-lg" />
            </div>

            <p class="text-center mt-3 mb-0 text-dark small">
                @Localizer["Text_NoAccount"]
                <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold">
                    @Localizer["Link_RegisterNow"]
                </a>
            </p>
        </form>
    </div>
</div>