@model List<MyWeb.Models.Book>
@{
    ViewData["Title"] = "Danh sách sách";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white fw-bold mb-1">Quản Lý Thư Viện</h2>
            <p class="text-light opacity-75 small">Danh sách các đầu sách hiện có trong hệ thống</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm px-4">
            <i class="fas fa-plus-circle me-2"></i>Thêm sách mới
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase text-secondary small fw-bold" style="width: 80px;">ID</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold">Tiêu đề</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold">Tác giả</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold">Năm XB</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold">Thể loại</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var book in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-light text-dark border">#@book.Id</span>
                                </td>
                                <td>
                                    <div class="fw-bold text-primary">@book.Title</div>
                                </td>
                                <td>
                                    <div class="text-dark">@book.Author</div>
                                </td>
                                <td>
                                    <span class="text-muted">@book.YearPublished</span>
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-info text-dark fw-normal">
                                        @(book.Category?.Name ?? "N/A")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Update" asp-route-id="@book.Id"
                                           class="btn btn-outline-warning btn-sm" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@book.Id"
                                           class="btn btn-outline-danger btn-sm" title="Xóa"
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa?')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<style>
    body {
        background-color: #f8f9fa; /* Màu nền xám nhạt cho nổi bật Card */
    }

    .table thead th {
        border-top: none;
        border-bottom: 2px solid #eee;
    }

    .table tbody tr {
        transition: all 0.2s ease;
    }

        .table tbody tr:hover {
            background-color: #f2f7ff !important; /* Hiệu ứng hover nhẹ nhàng */
            transform: scale(1.002);
        }

    .btn-group .btn {
        padding: 0.4rem 0.8rem;
    }
</style>