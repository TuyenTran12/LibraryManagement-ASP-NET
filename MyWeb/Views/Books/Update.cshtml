@model MyWeb.Models.Book
@{
    ViewData["Title"] = "Cập nhật sách";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white fw-bold mb-1">Cập Nhật Thông Tin</h2>
            <p class="text-light opacity-75 small">Chỉnh sửa chi tiết sách và lưu lại thay đổi</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light px-4 shadow-sm">
            <i class="fas fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <div class="card border-0 shadow-lg p-4" style="background-color: #f8f9fa; border-radius: 12px;">

                <form asp-action="Update" method="post">

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold text-dark">Tiêu đề sách</label>
                        <div class="input-group input-group-solid">
                            <span class="input-group-text bg-white border-0">
                                <i class="fas fa-book text-primary"></i>
                            </span>
                            <input asp-for="Title"
                                   class="form-control bg-white text-dark border-0 shadow-none"
                                   placeholder="Nhập tên sách..." />
                        </div>
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Author" class="form-label fw-bold text-dark">Tác giả</label>
                        <div class="input-group input-group-solid">
                            <span class="input-group-text bg-white border-0">
                                <i class="fas fa-user-edit text-primary"></i>
                            </span>
                            <input asp-for="Author"
                                   class="form-control bg-white text-dark border-0 shadow-none"
                                   placeholder="Tên tác giả..." />
                        </div>
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="YearPublished" class="form-label fw-bold text-dark">Năm xuất bản</label>
                            <div class="input-group input-group-solid">
                                <span class="input-group-text bg-white border-0">
                                    <i class="fas fa-calendar-alt text-primary"></i>
                                </span>
                                <input asp-for="YearPublished" type="number"
                                       class="form-control bg-white text-dark border-0 shadow-none"
                                       placeholder="YYYY" />
                            </div>
                            <span asp-validation-for="YearPublished" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoryId" class="form-label fw-bold text-dark">Thể loại</label>
                            <div class="input-group input-group-solid">
                                <span class="input-group-text bg-white border-0">
                                    <i class="fas fa-tags text-primary"></i>
                                </span>
                                <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                                        class="form-select bg-white text-dark border-0 shadow-none">
                                    <option value="">-- Chọn loại --</option>
                                </select>
                            </div>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-warning btn-lg fw-bold shadow border-dark text-dark">
                            <i class="fas fa-save me-2"></i>LƯU THAY ĐỔI
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    /* Tạo khung viền đen bao quanh toàn bộ cụm input */
    .input-group-solid {
        border: 2px solid #000000 !important; /* Viền đen dày 2px */
        border-radius: 6px;
        overflow: hidden; /* Cắt góc tròn cho nội dung bên trong */
        background-color: #ffffff; /* Nền trắng */
        display: flex;
    }

        /* Hiệu ứng khi click vào nhập liệu (Focus) */
        .input-group-solid:focus-within {
            border-color: #0d6efd !important; /* Đổi viền sang xanh khi nhập */
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.2);
        }

    /* Đảm bảo chữ trong ô nhập luôn màu đen */
    .form-control, .form-select {
        color: #000000 !important;
    }

        /* Màu chữ placeholder (gợi ý) */
        .form-control::placeholder {
            color: #888 !important;
        }

    /* Bỏ viền gạch dọc giữa icon và input */
    .input-group-text {
        border-right: none !important;
    }
</style>